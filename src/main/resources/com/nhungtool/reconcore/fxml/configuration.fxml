<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" styleClass="screen-root" spacing="16.0">
    <fx:define>
        <ToggleGroup fx:id="unitRuleGroup"/>
        <ToggleGroup fx:id="flowGroup"/>
    </fx:define>
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <VBox spacing="4.0">
            <Label text="Cấu hình xử lý" styleClass="screen-title"/>
            <Label text="Thiết lập quy tắc trước khi chạy đối chiếu" styleClass="screen-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Hủy thay đổi" styleClass="secondary-button"/>
        <Button text="Lưu cấu hình" styleClass="primary-button"/>
    </HBox>
    <HBox spacing="16.0" VBox.vgrow="ALWAYS">
        <VBox styleClass="panel-card" spacing="12.0" HBox.hgrow="ALWAYS">
            <Label text="Bộ máy so khớp &amp; AI" styleClass="section-title"/>
            <Label text="Chế độ so khớp" styleClass="field-label"/>
            <ComboBox promptText="Ưu tiên tên hàng (mờ)"/>
            <CheckBox text="Bật gợi ý AI khi rà soát" selected="true"/>
            <Label text="Ngưỡng tin cậy AI: 85%" styleClass="field-label"/>
            <Slider min="0" max="100" value="85"/>
            <Separator/>
            <CheckBox text="So khớp không phân biệt hoa thường" selected="true"/>
            <CheckBox text="Xóa khoảng trắng đầu/cuối" selected="true"/>
            <CheckBox text="Ưu tiên token số" selected="true"/>
            <CheckBox text="Chuẩn hóa dấu câu và ký tự phân tách" selected="true"/>
        </VBox>
        <VBox styleClass="panel-card" spacing="12.0" HBox.hgrow="ALWAYS">
            <Label text="Xử lý ngoại lệ" styleClass="section-title"/>
            <Label text="Quy tắc lệch đơn vị" styleClass="field-label"/>
            <RadioButton text="Cảnh báo và đưa vào rà soát" selected="true" toggleGroup="$unitRuleGroup"/>
            <RadioButton text="Chặn xử lý" toggleGroup="$unitRuleGroup"/>
            <Label text="Hàng không có trong XNT" styleClass="field-label"/>
            <ComboBox promptText="Đưa vào hàng đợi rà soát"/>
            <Label text="Luồng xử lý" styleClass="field-label"/>
            <RadioButton text="Dừng để rà soát sau khi ánh xạ" selected="true" toggleGroup="$flowGroup"/>
            <RadioButton text="Tự động tiếp tục khi đạt ngưỡng" toggleGroup="$flowGroup"/>
            <Separator/>
            <Label text="Cấu hình này đang bám các quy tắc nghiệp vụ hiện tại: ưu tiên tên hàng, sai lệch ĐVT chỉ cảnh báo, hàng ngoài XNT vẫn phải ra kết quả." wrapText="true" styleClass="muted-label"/>
        </VBox>
    </HBox>
</VBox>
