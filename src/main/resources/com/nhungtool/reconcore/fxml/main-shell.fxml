<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nhungtool.reconcore.ui.MainController"
            stylesheets="@../styles/app.css"
            styleClass="app-root">
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="10.0">
            <padding>
                <Insets top="10" right="12" bottom="10" left="12"/>
            </padding>
            <Label text="ReconCore" styleClass="app-title"/>
            <Label fx:id="periodLabel" styleClass="top-meta" maxWidth="260.0" textOverrun="ELLIPSIS"/>
            <Label fx:id="currentScreenLabel" styleClass="top-meta-emphasis" maxWidth="220.0" textOverrun="ELLIPSIS"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button fx:id="runReconciliationButton" text="Chạy đối chiếu" styleClass="primary-button" onAction="#handleRunReconciliation"/>
        </HBox>
    </top>
    <left>
        <VBox styleClass="sidebar" spacing="5.0" minWidth="190.0" prefWidth="212.0" maxWidth="224.0">
            <padding>
                <Insets top="14" right="10" bottom="14" left="10"/>
            </padding>
            <Label text="Đối chiếu doanh nghiệp" styleClass="sidebar-title" wrapText="true" maxWidth="190.0"/>
            <Label text="Kotlin + JavaFX + FXML" styleClass="sidebar-subtitle" wrapText="true"/>
            <VBox spacing="3.0" VBox.vgrow="ALWAYS">
                <Button fx:id="dashboardButton" text="Tổng quan" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="inputValidationButton" text="Đầu vào / Kiểm tra" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="configButton" text="Cấu hình" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="progressButton" text="Tiến trình xử lý" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="mappingReviewButton" text="Rà soát ánh xạ" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="unitReviewButton" text="Rà soát đơn vị" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="detailedResultsButton" text="Kết quả chi tiết" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="negativeInventoryButton" text="Âm kho" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="exportButton" text="Xuất báo cáo" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="historyButton" text="Lịch sử chạy" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="settingsButton" text="Thiết lập" styleClass="nav-button" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane styleClass="content-host">
            <StackPane fx:id="contentPane"/>
            <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="12.0" visible="false" managed="false" styleClass="loading-overlay">
                <ProgressIndicator prefWidth="48.0" prefHeight="48.0"/>
                <Label fx:id="loadingMessageLabel" styleClass="loading-message" wrapText="true"/>
            </VBox>
        </StackPane>
    </center>
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="18.0">
            <padding>
                <Insets top="7" right="12" bottom="7" left="12"/>
            </padding>
            <Label fx:id="systemStatusLabel" text="Hệ thống: Đang hoạt động" styleClass="status-ok"/>
            <Label fx:id="warningCountLabel" styleClass="status-warn" maxWidth="560.0" textOverrun="ELLIPSIS"/>
            <Label fx:id="lastRunLabel" styleClass="status-meta" maxWidth="260.0" textOverrun="ELLIPSIS"/>
        </HBox>
    </bottom>
</BorderPane>
