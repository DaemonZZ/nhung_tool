<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nhungtool.reconcore.ui.MainController"
            stylesheets="@../styles/app.css"
            styleClass="app-root">
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16.0">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Label text="ReconCore" styleClass="app-title"/>
            <Label fx:id="periodLabel" styleClass="top-meta"/>
            <Label fx:id="currentScreenLabel" styleClass="top-meta-emphasis"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Run Reconciliation" styleClass="primary-button" onAction="#handleRunReconciliation"/>
        </HBox>
    </top>
    <left>
        <VBox styleClass="sidebar" spacing="6.0" prefWidth="250.0">
            <padding>
                <Insets top="18" right="14" bottom="18" left="14"/>
            </padding>
            <Label text="Enterprise Recon" styleClass="sidebar-title"/>
            <Label text="Kotlin + JavaFX + FXML" styleClass="sidebar-subtitle"/>
            <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                <Button fx:id="dashboardButton" text="Workspace" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="inputValidationButton" text="Input / Validation" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="configButton" text="Configuration" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="progressButton" text="Execution Progress" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="mappingReviewButton" text="Mapping Review" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="unitReviewButton" text="Unit Review" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="detailedResultsButton" text="Detailed Results" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="negativeInventoryButton" text="Negative Inventory" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="exportButton" text="Export" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="historyButton" text="Run History" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="settingsButton" text="Settings" styleClass="nav-button" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-host"/>
    </center>
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="18.0">
            <padding>
                <Insets top="8" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="System: Active" styleClass="status-ok"/>
            <Label fx:id="warningCountLabel" styleClass="status-warn"/>
            <Label fx:id="lastRunLabel" styleClass="status-meta"/>
        </HBox>
    </bottom>
</BorderPane>
