<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nhungtool.reconcore.ui.MainController"
            stylesheets="@../styles/app.css"
            styleClass="app-root">
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16.0">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Label text="ReconCore" styleClass="app-title"/>
            <Label fx:id="periodLabel" styleClass="top-meta"/>
            <Label fx:id="currentScreenLabel" styleClass="top-meta-emphasis"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Chạy đối chiếu" styleClass="primary-button" onAction="#handleRunReconciliation"/>
        </HBox>
    </top>
    <left>
        <VBox styleClass="sidebar" spacing="6.0" prefWidth="250.0">
            <padding>
                <Insets top="18" right="14" bottom="18" left="14"/>
            </padding>
            <Label text="Đối chiếu doanh nghiệp" styleClass="sidebar-title"/>
            <Label text="Kotlin + JavaFX + FXML" styleClass="sidebar-subtitle"/>
            <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                <Button fx:id="dashboardButton" text="Tổng quan" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="inputValidationButton" text="Đầu vào / Kiểm tra" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="configButton" text="Cấu hình" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="progressButton" text="Tiến trình xử lý" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="mappingReviewButton" text="Rà soát ánh xạ" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="unitReviewButton" text="Rà soát đơn vị" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="detailedResultsButton" text="Kết quả chi tiết" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="negativeInventoryButton" text="Âm kho" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="exportButton" text="Xuất báo cáo" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="historyButton" text="Lịch sử chạy" styleClass="nav-button" maxWidth="Infinity"/>
                <Button fx:id="settingsButton" text="Thiết lập" styleClass="nav-button" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-host"/>
    </center>
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="18.0">
            <padding>
                <Insets top="8" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="Hệ thống: Đang hoạt động" styleClass="status-ok"/>
            <Label fx:id="warningCountLabel" styleClass="status-warn"/>
            <Label fx:id="lastRunLabel" styleClass="status-meta"/>
        </HBox>
    </bottom>
</BorderPane>
