<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nhungtool.reconcore.ui.controller.DashboardController"
      styleClass="screen-root" spacing="16.0">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

    <VBox spacing="10.0" styleClass="panel-card">
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <VBox spacing="4.0">
                <Label text="Bảng điều khiển tổng quan" styleClass="screen-title"/>
                <Label fx:id="currentPeriodLabel" styleClass="screen-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="workspaceStatusLabel" styleClass="pill-success"/>
        </HBox>
        <Label fx:id="workspaceSummaryLabel" styleClass="screen-subtitle" wrapText="true"/>
        <FlowPane hgap="10.0" vgap="10.0" styleClass="toolbar-box">
            <Button fx:id="validateFilesButton" text="Kiểm tra file" styleClass="primary-button" onAction="#handleOpenInputValidation"/>
            <Button fx:id="reviewMappingButton" text="Rà soát ánh xạ" styleClass="secondary-button" onAction="#handleOpenMappingReview"/>
            <Button fx:id="unitWarningsButton" text="Rà soát đơn vị" styleClass="secondary-button" onAction="#handleOpenUnitReview"/>
            <Button fx:id="detailedResultsButton" text="Kết quả chi tiết" styleClass="secondary-button" onAction="#handleOpenDetailedResults"/>
            <Button fx:id="negativeInventoryButton" text="Âm kho" styleClass="secondary-button" onAction="#handleOpenNegativeInventory"/>
        </FlowPane>
    </VBox>

    <GridPane hgap="16.0" vgap="16.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
        </columnConstraints>

        <VBox styleClass="panel-card" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Nguồn XNT" styleClass="section-title"/>
                <Label fx:id="xntStatusLabel" styleClass="pill-success"/>
            </HBox>
            <Label fx:id="xntFileLabel" styleClass="field-label" wrapText="true"/>
            <Label fx:id="xntMetaLabel" styleClass="muted-label" wrapText="true"/>
                    <Label text="Tab nhận diện" styleClass="field-label"/>
            <FlowPane fx:id="xntSheetsPane" hgap="8.0" vgap="8.0"/>
        </VBox>

        <VBox styleClass="panel-card" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Nguồn hóa đơn" styleClass="section-title"/>
                <Label fx:id="invoiceStatusLabel" styleClass="pill-success"/>
            </HBox>
            <Label fx:id="invoiceFileLabel" styleClass="field-label" wrapText="true"/>
            <Label fx:id="invoiceMetaLabel" styleClass="muted-label" wrapText="true"/>
                    <Label text="Tab nhận diện" styleClass="field-label"/>
            <FlowPane fx:id="invoiceSheetsPane" hgap="8.0" vgap="8.0"/>
        </VBox>
    </GridPane>

    <GridPane hgap="14.0" vgap="14.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
        </columnConstraints>

        <VBox fx:id="validationCard" styleClass="metric-card" spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label fx:id="validationTitleLabel" styleClass="metric-title"/>
            <Label fx:id="validationValueLabel" styleClass="metric-value"/>
            <Label fx:id="validationDetailLabel" styleClass="muted-label" wrapText="true"/>
        </VBox>

        <VBox fx:id="mappingCard" styleClass="metric-card" spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label fx:id="mappingTitleLabel" styleClass="metric-title"/>
            <Label fx:id="mappingValueLabel" styleClass="metric-value"/>
            <Label fx:id="mappingDetailLabel" styleClass="muted-label" wrapText="true"/>
        </VBox>

        <VBox fx:id="unitCard" styleClass="metric-card" spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label fx:id="unitTitleLabel" styleClass="metric-title"/>
            <Label fx:id="unitValueLabel" styleClass="metric-value"/>
            <Label fx:id="unitDetailLabel" styleClass="muted-label" wrapText="true"/>
        </VBox>

        <VBox fx:id="negativeCard" styleClass="metric-card" spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label fx:id="negativeTitleLabel" styleClass="metric-title"/>
            <Label fx:id="negativeValueLabel" styleClass="metric-value"/>
            <Label fx:id="negativeDetailLabel" styleClass="muted-label" wrapText="true"/>
        </VBox>
    </GridPane>
</VBox>
